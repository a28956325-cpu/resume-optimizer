# AI APIs
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/resume_optimizer

# Auth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Enable demo mode without API keys
NEXT_PUBLIC_DEMO_MODE=false

# iLovePDF API (optional – enables in-place PDF editing to preserve original formatting)
# Sign up at https://developer.ilovepdf.com to get your keys.
# Without these keys the app falls back to the react-pdf template renderer.
ILOVEPDF_PUBLIC_KEY=your_ilovepdf_public_key
ILOVEPDF_SECRET_KEY=your_ilovepdf_secret_key
